# All optional — the app runs fully local without any of these:
# embedded Postgres (PGlite in .data/), disk storage, mock AI, on-screen magic links.

# DATABASE_URL=postgres://...        # Neon Postgres (production)
# BLOB_READ_WRITE_TOKEN=...          # Vercel Blob for audio + photos (production)
# GEMINI_API_KEY=...                 # Google AI Studio key — real transcription/summaries (free tier)
# GEMINI_MODEL=gemini-flash-latest      # optional override
# RESEND_API_KEY=...                 # sends magic-link emails (production)
# AUTH_SECRET=...                    # long random string for session JWTs (production)
# APP_URL=https://your-domain.app    # canonical URL used inside magic links (production)
